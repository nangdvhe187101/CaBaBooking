                        <td>06/06/2025</td>
                    </tr>
                    <tr>
                        <td><strong>#BK2025005</strong></td>
                        <td>Hoàng Quốc Việt<br><small style="color:#94a3b8;">viet.hoang@email.com</small></td>
                        <td>Villa Sapa Mist<br><small style="color:#94a3b8;">Sapa, Lào Cai</small></td>
                        <td><span class="info-badge">Homestay</span></td>
                        <td>5 người</td>
                        <td><strong>₫5,600,000</strong></td>
                        <td><span style="color:#166534; font-weight:500;">Đã thanh toán</span></td>
                        <td><span class="status-badge confirmed">Đã xác nhận</span></td>
                        <td>07/06/2025</td>
                    </tr>
                </tbody>
            </table>

            <div class="pagination">
                <span style="color:#999;">« Trước</span>
                <span class="current">1</span>
                <a href="#">2</a>
