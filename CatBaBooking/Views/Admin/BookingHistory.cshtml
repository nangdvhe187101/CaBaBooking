                        <th>Khách hàng</th>
                        <th>Cơ sở</th>
                        <th>Loại hình</th>
                        <th>Số khách</th>
                        <th>Tổng tiền</th>
                        <th>Thanh toán</th>
                        <th>Trạng thái</th>
                        <th>Ngày đặt</th>
                    </tr>
                </thead>
                <tbody>
                    <tr>
                        <td><strong>#BK2025001</strong></td>
                        <td>Nguyễn Văn An<br><small style="color:#94a3b8;">an.nguyen@email.com</small></td>
                        <td>Homestay Đà Lạt Xanh<br><small style="color:#94a3b8;">45 Trần Phú, Đà Lạt</small></td>
                        <td><span class="info-badge">Homestay</span></td>
                        <td>3 người</td>
                        <td><strong>₫2,400,000</strong></td>
                        <td><span style="color:#166534; font-weight:500;">Đã thanh toán</span></td>
                        <td><span class="status-badge confirmed">Đã xác nhận</span></td>
                        <td>01/06/2025</td>
                    </tr>
                    <tr>
                        <td><strong>#BK2025002</strong></td>
                        <td>Trần Thị Bình<br><small style="color:#94a3b8;">binh.tran@email.com</small></td>
                        <td>Nhà hàng Phố Cổ<br><small style="color:#94a3b8;">12 Hội An, Quảng Nam</small></td>
                        <td><span class="info-badge">Nhà hàng</span></td>
                        <td>6 người</td>
                        <td><strong>₫1,800,000</strong></td>
                        <td><span style="color:#b45309; font-weight:500;">Thanh toán một phần</span></td>
                        <td><span class="status-badge pending">Đang chờ</span></td>
                        <td>03/06/2025</td>
                    </tr>
                    <tr>
                        <td><strong>#BK2025003</strong></td>
                        <td>Lê Minh Cường<br><small style="color:#94a3b8;">cuong.le@email.com</small></td>
                        <td>Homestay Hội An Garden<br><small style="color:#94a3b8;">Hội An, Quảng Nam</small></td>
                        <td><span class="info-badge">Homestay</span></td>
                        <td>2 người</td>
                        <td><strong>₫3,200,000</strong></td>
                        <td><span style="color:#b91c1c; font-weight:500;">Chưa thanh toán</span></td>
                        <td><span class="status-badge cancelled">Đã hủy</span></td>
                        <td>05/06/2025</td>
                    </tr>
                    <tr>
                        <td><strong>#BK2025004</strong></td>
                        <td>Phạm Thu Dung<br><small style="color:#94a3b8;">dung.pham@email.com</small></td>
                        <td>Quán Ăn Bà Ngoại<br><small style="color:#94a3b8;">18 Lê Lợi, TP.HCM</small></td>
