@{
Layout = null;
}

<!DOCTYPE html>
<html lang="vi">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Booking Của Tôi - Cát Bà Booking</title>
    <link rel="stylesheet" href="~/css/HomePage/home-style.css">
    <link href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.4.0/css/all.min.css" rel="stylesheet">
    <style>
        /* ===== PAGE WRAPPER ===== */
        .account-page { background: #f5f7fb; min-height: 100vh; }
        .account-container { max-width: 1100px; margin: 0 auto; padding: 36px 24px 64px; }

        /* ===== BREADCRUMB ===== */
        .breadcrumb { display: flex; align-items: center; gap: 8px; font-size: 14px; color: #6b7280; margin-bottom: 28px; }
        .breadcrumb a { color: #059669; text-decoration: none; font-weight: 500; }
        .breadcrumb a:hover { text-decoration: underline; }
        .breadcrumb i.sep { font-size: 10px; color: #9ca3af; }

        /* ===== TRAVELOKA-STYLE 2-COLUMN LAYOUT ===== */
        .account-layout { display: grid; grid-template-columns: 280px 1fr; gap: 24px; align-items: start; }

        /* ===== LEFT SIDEBAR ===== */
        .account-sidebar { position: sticky; top: 24px; }
        .sidebar-profile { background: #fff; border: 1px solid #e5e7eb; border-radius: 16px; overflow: hidden; box-shadow: 0 2px 10px rgba(0,0,0,.05); }
        .sidebar-profile__header { background: linear-gradient(135deg, #059669, #065f46); padding: 24px 20px; text-align: center; }
        .sidebar-avatar { width: 68px; height: 68px; border-radius: 50%; background: rgba(255,255,255,.2); border: 3px solid rgba(255,255,255,.5); display: flex; align-items: center; justify-content: center; font-size: 26px; color: white; font-weight: 700; margin: 0 auto 12px; }
        .sidebar-profile__name { color: white; font-size: 16px; font-weight: 700; margin: 0 0 4px; }
        .sidebar-profile__sub { color: rgba(255,255,255,.75); font-size: 13px; }
        .sidebar-badge { display: inline-flex; align-items: center; gap: 5px; background: rgba(255,255,255,.15); color: white; font-size: 12px; font-weight: 600; padding: 4px 12px; border-radius: 999px; margin-top: 10px; }
        .sidebar-points { display: flex; align-items: center; justify-content: space-between; padding: 12px 20px; border-top: 1px solid #f3f4f6; }
        .sidebar-points__label { font-size: 13px; color: #6b7280; display: flex; align-items: center; gap: 8px; }
        .sidebar-points__value { font-size: 14px; font-weight: 700; color: #111827; }
        .sidebar-nav { padding: 8px 0; }
        .sidebar-nav-item { display: flex; align-items: center; gap: 12px; padding: 12px 20px; color: #374151; font-size: 14px; font-weight: 500; text-decoration: none; transition: all .2s; border-left: 3px solid transparent; }
        .sidebar-nav-item i { width: 18px; text-align: center; color: #9ca3af; transition: color .2s; font-size: 15px; }
        .sidebar-nav-item:hover { background: #f0fdf4; color: #059669; border-left-color: #059669; }
        .sidebar-nav-item:hover i { color: #059669; }
        .sidebar-nav-item.is-active { background: #ecfdf5; color: #059669; font-weight: 600; border-left-color: #059669; }
        .sidebar-nav-item.is-active i { color: #059669; }
        .sidebar-nav-divider { height: 1px; background: #f3f4f6; margin: 6px 0; }
        .sidebar-nav-item.logout { color: #dc2626; }
        .sidebar-nav-item.logout i { color: #dc2626; }
        .sidebar-nav-item.logout:hover { background: #fef2f2; border-left-color: #dc2626; }

        /* ===== RIGHT CONTENT ===== */
        .account-content { min-width: 0; }

        /* Page header */
        .page-header { display: flex; align-items: flex-end; justify-content: space-between; flex-wrap: wrap; gap: 16px; margin-bottom: 24px; }
        .page-header h1 { font-size: 24px; font-weight: 700; color: #111827; margin: 0 0 4px; }
        .page-header p { color: #6b7280; margin: 0; font-size: 14px; }

        /* Stat cards */
        .stats-grid { display: grid; grid-template-columns: repeat(4, 1fr); gap: 12px; margin-bottom: 24px; }
        .stat-card { background: #fff; border: 1px solid #e5e7eb; border-radius: 14px; padding: 16px 18px; box-shadow: 0 2px 8px rgba(0,0,0,.04); display: flex; align-items: center; gap: 14px; }
        .stat-card__icon { width: 42px; height: 42px; border-radius: 12px; display: flex; align-items: center; justify-content: center; font-size: 18px; flex-shrink: 0; }
        .stat-card__icon.all  { background: #eff6ff; color: #2563eb; }
        .stat-card__icon.conf { background: #ecfdf5; color: #059669; }
        .stat-card__icon.pend { background: #fffbeb; color: #d97706; }
        .stat-card__icon.canc { background: #fef2f2; color: #dc2626; }
        .stat-card__value { font-size: 22px; font-weight: 700; color: #111827; line-height: 1; }
        .stat-card__label { font-size: 12px; color: #6b7280; margin-top: 3px; }

        /* Filter tabs */
        .filter-bar { display: flex; align-items: center; gap: 8px; margin-bottom: 20px; flex-wrap: wrap; }
        .filter-tab { display: inline-flex; align-items: center; gap: 6px; padding: 8px 16px; border-radius: 999px; border: 1.5px solid #e5e7eb; background: #fff; color: #374151; font-weight: 600; font-size: 13px; text-decoration: none; transition: all .2s; cursor: pointer; }
        .filter-tab:hover { border-color: #059669; color: #059669; }
        .filter-tab.is-active { background: #059669; border-color: #059669; color: #fff; box-shadow: 0 4px 14px rgba(5,150,105,.3); }
        .filter-tab .badge { border-radius: 999px; padding: 1px 7px; font-size: 11px; margin-left: 2px; }
        .filter-tab.is-active .badge { background: rgba(255,255,255,.25); }
        .filter-tab:not(.is-active) .badge { background: #f3f4f6; color: #6b7280; }

        /* Booking cards */
        .bookings-list { display: flex; flex-direction: column; gap: 14px; }
        .booking-card { background: #fff; border: 1px solid #e5e7eb; border-radius: 16px; overflow: hidden; box-shadow: 0 2px 10px rgba(0,0,0,.05); transition: box-shadow .2s, transform .2s; }
        .booking-card:hover { box-shadow: 0 8px 28px rgba(0,0,0,.10); transform: translateY(-2px); }
        .booking-card__top { display: flex; align-items: stretch; }
        .booking-card__stripe { width: 5px; flex-shrink: 0; }
        .booking-card__stripe.confirmed { background: #059669; }
        .booking-card__stripe.pending   { background: #d97706; }
        .booking-card__stripe.cancelled { background: #dc2626; }
        .booking-card__main { flex: 1; padding: 20px 22px; }
        .booking-card__head { display: flex; align-items: flex-start; justify-content: space-between; flex-wrap: wrap; gap: 10px; margin-bottom: 16px; }
        .booking-card__title { display: flex; align-items: center; gap: 10px; }
        .booking-card__icon { width: 36px; height: 36px; border-radius: 10px; display: flex; align-items: center; justify-content: center; font-size: 15px; }
        .booking-card__icon.homestay { background: #ecfdf5; color: #059669; }
        .booking-card__icon.restaurant { background: #fff7ed; color: #ea580c; }
        .booking-card__name { font-size: 15px; font-weight: 700; color: #111827; }
        .booking-card__code { font-size: 12px; color: #9ca3af; margin-top: 2px; }
        .status-badge { display: inline-flex; align-items: center; gap: 6px; padding: 5px 12px; border-radius: 999px; font-size: 12px; font-weight: 600; }
        .status-badge.confirmed { background: #ecfdf5; color: #065f46; }
        .status-badge.pending   { background: #fffbeb; color: #92400e; }
        .status-badge.cancelled { background: #fef2f2; color: #991b1b; }
        .status-badge .dot { width: 7px; height: 7px; border-radius: 50%; }
        .status-badge.confirmed .dot { background: #059669; }
        .status-badge.pending   .dot { background: #d97706; }
        .status-badge.cancelled .dot { background: #dc2626; }
        .booking-card__meta { display: grid; grid-template-columns: repeat(auto-fit, minmax(130px, 1fr)); gap: 10px 16px; }
        .meta-item__label { font-size: 11px; text-transform: uppercase; letter-spacing: .06em; color: #9ca3af; font-weight: 600; }
        .meta-item__value { font-size: 13px; font-weight: 600; color: #1f2937; margin-top: 3px; }
        .booking-card__foot { border-top: 1px solid #f3f4f6; padding: 11px 22px; display: flex; align-items: center; justify-content: space-between; background: #fafafa; }
        .booking-card__email { font-size: 13px; color: #6b7280; display: flex; align-items: center; gap: 6px; }
        .btn-detail { display: inline-flex; align-items: center; gap: 6px; background: #059669; color: #fff; text-decoration: none; padding: 7px 16px; border-radius: 8px; font-size: 13px; font-weight: 600; transition: background .2s; }
        .btn-detail:hover { background: #047857; }

        @@media (max-width: 900px) { .account-layout { grid-template-columns: 1fr; } .account-sidebar { position: static; } }
        @@media (max-width: 768px) { .stats-grid { grid-template-columns: repeat(2, 1fr); } }
    </style>
</head>
<body>

@await Html.PartialAsync("Sidebar")

<div class="account-page">
    <div class="account-container">

        <!-- Breadcrumb -->
        <nav class="breadcrumb">
            <a href="/home-page"><i class="fas fa-home"></i> Trang chủ</a>
            <i class="fas fa-chevron-right sep"></i>
            <span>Đặt chỗ của tôi</span>
        </nav>

        <div class="account-layout">

            <!-- ===== LEFT SIDEBAR ===== -->
            <aside class="account-sidebar">
                <div class="sidebar-profile">
                    <div class="sidebar-profile__header">
                        <div class="sidebar-avatar">VN</div>
                        <p class="sidebar-profile__name">Nguyễn Văn A</p>
                        <p class="sidebar-profile__sub">nguyenvana@email.com</p>
                        <div class="sidebar-badge"><i class="fas fa-medal"></i> Bronze Priority</div>
                    </div>

                    <div class="sidebar-points">
                        <span class="sidebar-points__label"><i class="fas fa-coins" style="color:#d97706;"></i> Điểm thưởng</span>
                        <span class="sidebar-points__value">0 điểm</span>
                    </div>

                    <nav class="sidebar-nav">
                        <a href="/my-bookings" class="sidebar-nav-item is-active">
                            <i class="fas fa-calendar-check"></i> Đặt chỗ của tôi
                        </a>
                        <a href="#" class="sidebar-nav-item">
                            <i class="fas fa-list-alt"></i> Danh sách giao dịch
                        </a>
                        <a href="#" class="sidebar-nav-item">
                            <i class="fas fa-undo-alt"></i> Thanh toán &amp; Hoàn tiền
                        </a>
                        <a href="#" class="sidebar-nav-item">
                            <i class="fas fa-bell"></i> Thông báo giá vé
                        </a>
                        <a href="#" class="sidebar-nav-item">
                            <i class="fas fa-users"></i> Hành khách đã lưu
                        </a>
                        <a href="#" class="sidebar-nav-item">
                            <i class="fas fa-sliders-h"></i> Cài đặt thông báo
                        </a>
                        <div class="sidebar-nav-divider"></div>
                        <a href="/profile" class="sidebar-nav-item">
                            <i class="fas fa-cog"></i> Tài khoản
                        </a>
                        <div class="sidebar-nav-divider"></div>
                        <a href="#" class="sidebar-nav-item logout" onclick="return confirm('Bạn có chắc muốn đăng xuất?')">
                            <i class="fas fa-sign-out-alt"></i> Đăng xuất
                        </a>
                    </nav>
                </div>
            </aside>

            <!-- ===== RIGHT CONTENT ===== -->
            <main class="account-content">

                <div class="page-header">
                    <div>
                        <h1><i class="fas fa-calendar-check" style="color:#059669;font-size:22px;"></i> Booking Của Tôi</h1>
                        <p>Quản lý tất cả đặt chỗ homestay và nhà hàng của bạn</p>
                    </div>
                </div>

                <!-- Stats -->
                <div class="stats-grid">
                    <div class="stat-card">
                        <div class="stat-card__icon all"><i class="fas fa-layer-group"></i></div>
                        <div><div class="stat-card__value">3</div><div class="stat-card__label">Tổng booking</div></div>
                    </div>
                    <div class="stat-card">
                        <div class="stat-card__icon conf"><i class="fas fa-check-circle"></i></div>
                        <div><div class="stat-card__value">1</div><div class="stat-card__label">Đã xác nhận</div></div>
                    </div>
                    <div class="stat-card">
                        <div class="stat-card__icon pend"><i class="fas fa-clock"></i></div>
                        <div><div class="stat-card__value">1</div><div class="stat-card__label">Chờ xác nhận</div></div>
                    </div>
                    <div class="stat-card">
                        <div class="stat-card__icon canc"><i class="fas fa-times-circle"></i></div>
                        <div><div class="stat-card__value">1</div><div class="stat-card__label">Đã hủy</div></div>
                    </div>
                </div>

                <!-- Filter tabs -->
                <div class="filter-bar">
                    <button class="filter-tab is-active">Tất cả <span class="badge">3</span></button>
                    <button class="filter-tab">Đã xác nhận <span class="badge">1</span></button>
                    <button class="filter-tab">Chờ xác nhận <span class="badge">1</span></button>
                    <button class="filter-tab">Đã hủy <span class="badge">1</span></button>
                </div>

                <!-- Booking list -->
                <div class="bookings-list">

                    <!-- Booking 1 - Confirmed / Homestay -->
                    <div class="booking-card">
                        <div class="booking-card__top">
                            <div class="booking-card__stripe confirmed"></div>
                            <div class="booking-card__main">
                                <div class="booking-card__head">
                                    <div class="booking-card__title">
                                        <div class="booking-card__icon homestay"><i class="fas fa-home"></i></div>
                                        <div>
                                            <div class="booking-card__name">Homestay Ocean View Cát Bà</div>
                                            <div class="booking-card__code">#CB2025001 · Homestay</div>
                                        </div>
                                    </div>
                                    <span class="status-badge confirmed"><span class="dot"></span> Đã xác nhận</span>
                                </div>
                                <div class="booking-card__meta">
                                    <div class="meta-item">
                                        <div class="meta-item__label"><i class="fas fa-map-marker-alt"></i> Địa điểm</div>
                                        <div class="meta-item__value">Cát Cò 1, Cát Bà</div>
                                    </div>
                                    <div class="meta-item">
                                        <div class="meta-item__label"><i class="fas fa-calendar-alt"></i> Nhận phòng</div>
                                        <div class="meta-item__value">15/06/2025</div>
                                    </div>
                                    <div class="meta-item">
                                        <div class="meta-item__label"><i class="fas fa-calendar-alt"></i> Trả phòng</div>
                                        <div class="meta-item__value">18/06/2025</div>
                                    </div>
                                    <div class="meta-item">
                                        <div class="meta-item__label"><i class="fas fa-users"></i> Số khách</div>
                                        <div class="meta-item__value">2 người</div>
                                    </div>
                                    <div class="meta-item">
                                        <div class="meta-item__label"><i class="fas fa-money-bill-wave"></i> Tổng tiền</div>
                                        <div class="meta-item__value" style="color:#059669;">2,550,000₫</div>
                                    </div>
                                </div>
                            </div>
                        </div>
                        <div class="booking-card__foot">
                            <div class="booking-card__email"><i class="fas fa-envelope"></i> nguyenvana@email.com</div>
                            <a href="/booking-detail" class="btn-detail">Xem chi tiết <i class="fas fa-arrow-right"></i></a>
                        </div>
                    </div>

                    <!-- Booking 2 - Pending / Restaurant -->
                    <div class="booking-card">
                        <div class="booking-card__top">
                            <div class="booking-card__stripe pending"></div>
                            <div class="booking-card__main">
                                <div class="booking-card__head">
                                    <div class="booking-card__title">
                                        <div class="booking-card__icon restaurant"><i class="fas fa-utensils"></i></div>
                                        <div>
                                            <div class="booking-card__name">Nhà hàng Biển Xanh</div>
                                            <div class="booking-card__code">#CB2025002 · Nhà hàng</div>
                                        </div>
                                    </div>
                                    <span class="status-badge pending"><span class="dot"></span> Chờ xác nhận</span>
                                </div>
                                <div class="booking-card__meta">
                                    <div class="meta-item">
                                        <div class="meta-item__label"><i class="fas fa-map-marker-alt"></i> Địa điểm</div>
                                        <div class="meta-item__value">Bến Bèo, Cát Bà</div>
                                    </div>
                                    <div class="meta-item">
                                        <div class="meta-item__label"><i class="fas fa-calendar-alt"></i> Ngày</div>
                                        <div class="meta-item__value">20/06/2025</div>
                                    </div>
                                    <div class="meta-item">
                                        <div class="meta-item__label"><i class="fas fa-clock"></i> Giờ</div>
                                        <div class="meta-item__value">19:00 – 21:00</div>
                                    </div>
                                    <div class="meta-item">
                                        <div class="meta-item__label"><i class="fas fa-users"></i> Số khách</div>
                                        <div class="meta-item__value">4 người</div>
                                    </div>
                                    <div class="meta-item">
                                        <div class="meta-item__label"><i class="fas fa-money-bill-wave"></i> Tổng tiền</div>
                                        <div class="meta-item__value" style="color:#059669;">850,000₫</div>
                                    </div>
                                </div>
                            </div>
                        </div>
                        <div class="booking-card__foot">
                            <div class="booking-card__email"><i class="fas fa-envelope"></i> nguyenvana@email.com</div>
                            <a href="/booking-detail" class="btn-detail">Xem chi tiết <i class="fas fa-arrow-right"></i></a>
                        </div>
                    </div>

                    <!-- Booking 3 - Cancelled / Homestay -->
                    <div class="booking-card">
                        <div class="booking-card__top">
                            <div class="booking-card__stripe cancelled"></div>
                            <div class="booking-card__main">
                                <div class="booking-card__head">
                                    <div class="booking-card__title">
                                        <div class="booking-card__icon homestay"><i class="fas fa-home"></i></div>
                                        <div>
                                            <div class="booking-card__name">Villa Hải Đăng Cát Bà</div>
                                            <div class="booking-card__code">#CB2025003 · Homestay</div>
                                        </div>
                                    </div>
                                    <span class="status-badge cancelled"><span class="dot"></span> Đã hủy</span>
                                </div>
                                <div class="booking-card__meta">
                                    <div class="meta-item">
                                        <div class="meta-item__label"><i class="fas fa-map-marker-alt"></i> Địa điểm</div>
                                        <div class="meta-item__value">Cát Cò 2, Cát Bà</div>
                                    </div>
                                    <div class="meta-item">
                                        <div class="meta-item__label"><i class="fas fa-calendar-alt"></i> Nhận phòng</div>
                                        <div class="meta-item__value">10/05/2025</div>
                                    </div>
                                    <div class="meta-item">
                                        <div class="meta-item__label"><i class="fas fa-calendar-alt"></i> Trả phòng</div>
                                        <div class="meta-item__value">12/05/2025</div>
                                    </div>
                                    <div class="meta-item">
                                        <div class="meta-item__label"><i class="fas fa-users"></i> Số khách</div>
                                        <div class="meta-item__value">3 người</div>
                                    </div>
                                    <div class="meta-item">
                                        <div class="meta-item__label"><i class="fas fa-money-bill-wave"></i> Tổng tiền</div>
                                        <div class="meta-item__value" style="color:#6b7280;text-decoration:line-through;">2,400,000₫</div>
                                    </div>
                                </div>
                            </div>
                        </div>
                        <div class="booking-card__foot">
                            <div class="booking-card__email"><i class="fas fa-envelope"></i> nguyenvana@email.com</div>
                            <a href="/booking-detail" class="btn-detail" style="background:#6b7280;">Xem chi tiết <i class="fas fa-arrow-right"></i></a>
                        </div>
                    </div>

                </div><!-- /bookings-list -->
            </main>

        </div><!-- /account-layout -->
    </div><!-- /account-container -->
</div><!-- /account-page -->

@await Html.PartialAsync("Footer")

</body>
</html>
