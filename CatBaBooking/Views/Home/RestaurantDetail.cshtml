

@{
    Layout = null;
}
<!DOCTYPE html>
<html lang="vi">
<head>
    <meta charset="UTF-8">
    <title>Nhà hàng Hải Sản Cát Bà - Chi tiết nhà hàng</title>
    <link rel="stylesheet" href="~/css/HomePage/home-style.css">
    <link rel="stylesheet" href="~/css/HomePage/restaurantdetail-style.css">
    <link href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.4.0/css/all.min.css" rel="stylesheet">
    <style>
        .menu-header{display:flex;justify-content:space-between;align-items:center;flex-wrap:wrap;}
        .menu-search{position:relative;margin-top:10px;}
        .menu-search input[type="text"]{padding:8px 12px 8px 35px;border:1px solid #ccc;border-radius:20px;width:250px;font-size:14px;}
        .menu-search .fa-search{position:absolute;left:12px;top:50%;transform:translateY(-50%);color:#888;font-size:14px;}
        .pagination{display:flex;justify-content:center;align-items:center;gap:8px;margin:30px 0;flex-wrap:wrap;}
        .page-btn{min-width:40px;height:40px;padding:0 12px;border:1px solid #ddd;border-radius:6px;background:#fff;color:#6c757d;font-size:14px;text-decoration:none;display:flex;align-items:center;justify-content:center;transition:all .2s;cursor:pointer;}
        .page-btn.active{background-color:#28a745;color:white;border-color:#28a745;font-weight:600;}
        .page-btn:disabled{color:#aaa;background-color:#f8f9fa;cursor:not-allowed;}
        .header{background:linear-gradient(135deg,#059669,#065f46);color:white;}
        .main-nav{padding:1rem 0;}
        .nav-content{display:flex;justify-content:space-between;align-items:center;}
        .logo{font-size:1.5rem;font-weight:bold;display:flex;align-items:center;text-decoration:none;}
        .logo-main{color:white;}.logo-sub{color:#a7f3d0;margin-left:.25rem;}
        .nav-links{display:flex;align-items:center;gap:2rem;}
        .nav-link{color:white;text-decoration:none;display:flex;align-items:center;gap:.25rem;}
    </style>
</head>
<body>
    @await Html.PartialAsync("Sidebar")

    <main class="restaurant-detail-page">
        <div class="container detail-layout">
            <section class="left-side">
                <div class="restaurant-header-card">
                    <div class="restaurant-cover">
                        <img src="https://images.unsplash.com/photo-1514190051997-0f6f39ca5cde?w=900&h=400&fit=crop" alt="Nhà hàng Hải Sản Cát Bà">
                    </div>
                    <div class="restaurant-main-info">
                        <div class="restaurant-top-row">
                            <div class="restaurant-name-rating">
                                <h1>Nhà hàng Hải Sản Cát Bà</h1>
                                <div class="rating-line">
                                    <span class="score">4.5 /5</span>
                                    <div class="stars"><i class="fas fa-star"></i><i class="fas fa-star"></i><i class="fas fa-star"></i><i class="fas fa-star"></i><i class="fas fa-star-half-alt"></i></div>
                                    <span class="reviews-count">(215 đánh giá)</span>
                                </div>
                            </div>
                            <div class="restaurant-meta">
                                <div class="restaurant-meta-row"><i class="fas fa-map-marker-alt"></i><span>Cát Cò 1, Hải Phòng</span></div>
                                <div class="restaurant-meta-row"><i class="fas fa-users"></i><span>Sức chứa: 150 khách</span></div>
                                <div class="restaurant-meta-row"><i class="far fa-clock"></i><span>Giờ mở cửa: 08:00 - 22:00</span></div>
                                <div class="restaurant-meta-row"><i class="fas fa-phone"></i><span>028 3456 7899</span></div>
                            </div>
                        </div>
                        <div class="restaurant-desc">Nhà hàng chuyên các món hải sản tươi ngon từ vịnh Lan Hạ. Không gian thoáng mát, phục vụ tận tình. Đặc biệt nổi tiếng với các món tôm hùm, cua biển và cá song.</div>
                        <div class="restaurant-tags">
                            <span class="tag-pill">Hải sản</span>
                            <span class="tag-pill">Đặc sản biển</span>
                            <span class="tag-pill">View đẹp</span>
                        </div>
                    </div>
                </div>

                <section class="menu-section">
                    <div class="menu-header">
                        <div class="menu-header-left">
                            <h2>Thực đơn Nhà hàng Hải Sản Cát Bà</h2>
                            <p>Chọn món bạn muốn gọi. Nhấn "Thêm" để bỏ vào hóa đơn.</p>
                        </div>
                        <div class="menu-search">
                            <i class="fas fa-search"></i>
                            <input type="text" id="dishSearchInput" placeholder="Tìm món trong thực đơn...">
                        </div>
                    </div>

                    <div class="menu-list">
                        <div class="dish-card" data-dish-name="Tôm Hùm Nướng Muối Ớt" data-dish-price="450000" data-dish-category="Hải sản" data-dish-availability="Đang bán" data-is-available="true" data-dish-id="1" data-dish-image="https://images.unsplash.com/photo-1551504734-5ee1c4a1479b?w=300&h=200&fit=crop" data-dish-description="Tôm hùm tươi nướng muối ớt thơm ngon, phục vụ kèm rau sống và nước chấm đặc biệt.">
                            <div class="dish-image"><img src="https://images.unsplash.com/photo-1551504734-5ee1c4a1479b?w=300&h=200&fit=crop" alt="Tôm Hùm Nướng"></div>
                            <div class="dish-content">
                                <div class="dish-top-row"><div class="dish-name">Tôm Hùm Nướng Muối Ớt</div><div class="dish-price">450,000 ₫</div></div>
                                <div class="dish-actions"><div class="availability text-success"><i class="fas fa-check-circle"></i><span>Đang bán</span></div><button class="add-btn" type="button">+ Thêm</button></div>
                            </div>
                        </div>
                        <div class="dish-card" data-dish-name="Cua Biển Rang Muối" data-dish-price="350000" data-dish-category="Hải sản" data-dish-availability="Đang bán" data-is-available="true" data-dish-id="2" data-dish-image="https://images.unsplash.com/photo-1498654896293-37aacf113fd9?w=300&h=200&fit=crop" data-dish-description="Cua biển rang muối giòn ngon, thơm lừng.">
                            <div class="dish-image"><img src="https://images.unsplash.com/photo-1498654896293-37aacf113fd9?w=300&h=200&fit=crop" alt="Cua Biển"></div>
                            <div class="dish-content">
                                <div class="dish-top-row"><div class="dish-name">Cua Biển Rang Muối</div><div class="dish-price">350,000 ₫</div></div>
                                <div class="dish-actions"><div class="availability text-success"><i class="fas fa-check-circle"></i><span>Đang bán</span></div><button class="add-btn" type="button">+ Thêm</button></div>
                            </div>
                        </div>
                        <div class="dish-card" data-dish-name="Cá Song Hấp Xì Dầu" data-dish-price="280000" data-dish-category="Hải sản" data-dish-availability="Đang bán" data-is-available="true" data-dish-id="3" data-dish-image="https://images.unsplash.com/photo-1559847844-5315695dadae?w=300&h=200&fit=crop" data-dish-description="Cá song tươi hấp xì dầu kiểu Hồng Kông.">
                            <div class="dish-image"><img src="https://images.unsplash.com/photo-1559847844-5315695dadae?w=300&h=200&fit=crop" alt="Cá Song"></div>
                            <div class="dish-content">
                                <div class="dish-top-row"><div class="dish-name">Cá Song Hấp Xì Dầu</div><div class="dish-price">280,000 ₫</div></div>
                                <div class="dish-actions"><div class="availability text-success"><i class="fas fa-check-circle"></i><span>Đang bán</span></div><button class="add-btn" type="button">+ Thêm</button></div>
                            </div>
                        </div>
                        <div class="dish-card" data-dish-name="Mực Nướng Mỡ Hành" data-dish-price="180000" data-dish-category="Hải sản" data-dish-availability="Đang bán" data-is-available="true" data-dish-id="4" data-dish-image="https://images.unsplash.com/photo-1604909052743-94e838986d24?w=300&h=200&fit=crop" data-dish-description="Mực tươi nướng mỡ hành thơm lừng.">
                            <div class="dish-image"><img src="https://images.unsplash.com/photo-1604909052743-94e838986d24?w=300&h=200&fit=crop" alt="Mực Nướng"></div>
                            <div class="dish-content">
                                <div class="dish-top-row"><div class="dish-name">Mực Nướng Mỡ Hành</div><div class="dish-price">180,000 ₫</div></div>
                                <div class="dish-actions"><div class="availability text-success"><i class="fas fa-check-circle"></i><span>Đang bán</span></div><button class="add-btn" type="button">+ Thêm</button></div>
                            </div>
                        </div>
                        <div class="dish-card" data-dish-name="Ghẹ Hấp Bia" data-dish-price="220000" data-dish-category="Hải sản" data-dish-availability="Hết món" data-is-available="false" data-dish-id="5" data-dish-image="https://images.unsplash.com/photo-1563379091339-03b21ab4a4f8?w=300&h=200&fit=crop" data-dish-description="Ghẹ hấp bia tươi ngon.">
                            <div class="dish-image"><img src="https://images.unsplash.com/photo-1563379091339-03b21ab4a4f8?w=300&h=200&fit=crop" alt="Ghẹ Hấp"></div>
                            <div class="dish-content">
                                <div class="dish-top-row"><div class="dish-name">Ghẹ Hấp Bia</div><div class="dish-price">220,000 ₫</div></div>
                                <div class="dish-actions"><div class="availability text-danger"><i class="fas fa-times-circle"></i><span>Hết món</span></div><button class="add-btn" disabled>+ Thêm</button></div>
                            </div>
                        </div>
                        <div class="dish-card" data-dish-name="Canh Chua Cá" data-dish-price="95000" data-dish-category="Canh" data-dish-availability="Đang bán" data-is-available="true" data-dish-id="6" data-dish-image="https://images.unsplash.com/photo-1547592166-23ac45744acd?w=300&h=200&fit=crop" data-dish-description="Canh chua cá đặc trưng miền Nam.">
                            <div class="dish-image"><img src="https://images.unsplash.com/photo-1547592166-23ac45744acd?w=300&h=200&fit=crop" alt="Canh Chua"></div>
                            <div class="dish-content">
                                <div class="dish-top-row"><div class="dish-name">Canh Chua Cá</div><div class="dish-price">95,000 ₫</div></div>
                                <div class="dish-actions"><div class="availability text-success"><i class="fas fa-check-circle"></i><span>Đang bán</span></div><button class="add-btn" type="button">+ Thêm</button></div>
                            </div>
                        </div>
                        <div id="noResultsMessage" class="no-dishes-message" style="display:none;"><p>Không tìm thấy món ăn nào phù hợp.</p></div>
                    </div>
                </section>

                <!-- Reviews -->
                <section class="reviews-section" style="margin-top:40px;padding:24px;background:#fff;border-radius:12px;box-shadow:0 2px 8px rgba(0,0,0,.1);">
                    <h2 style="font-size:24px;margin-bottom:20px;color:#333;"><i class="fas fa-comments" style="margin-right:8px;"></i>Đánh giá từ khách</h2>
                    <div class="reviews-list">
                        <div class="review-item" style="padding:16px;border-bottom:1px solid #eee;margin-bottom:16px;">
                            <div style="display:flex;align-items:center;margin-bottom:8px;">
                                <div style="font-weight:600;color:#333;margin-right:12px;">Trần Thị B</div>
                                <div style="color:#ffc107;"><i class="fas fa-star"></i><i class="fas fa-star"></i><i class="fas fa-star"></i><i class="fas fa-star"></i><i class="fas fa-star"></i></div>
                                <div style="margin-left:auto;color:#999;font-size:14px;">15/05/2025</div>
                            </div>
                            <div style="color:#666;line-height:1.6;">Tôm hùm rất tươi ngon, phục vụ nhiệt tình. Không gian đẹp nhìn ra biển.</div>
                        </div>
                        <div class="review-item" style="padding:16px;border-bottom:1px solid #eee;">
                            <div style="display:flex;align-items:center;margin-bottom:8px;">
                                <div style="font-weight:600;color:#333;margin-right:12px;">Lê Văn C</div>
                                <div style="color:#ffc107;"><i class="fas fa-star"></i><i class="fas fa-star"></i><i class="fas fa-star"></i><i class="fas fa-star"></i><i class="far fa-star"></i></div>
                                <div style="margin-left:auto;color:#999;font-size:14px;">02/06/2025</div>
                            </div>
                            <div style="color:#666;line-height:1.6;">Giá cả hợp lý, đồ ăn ngon. Sẽ quay lại lần sau!</div>
                        </div>
                    </div>
                </section>
            </section>

            <!-- Order Summary -->
            <aside class="order-summary-wrapper">
                <div class="order-summary-card">
                    <div class="order-header"><div class="order-header-title"><h3>Đơn gọi món</h3></div></div>
                    <div class="order-items" id="orderItems">
                        <div class="empty-cart-message">
                            <i class="fas fa-shopping-cart"></i>
                            <p>Giỏ hàng trống<br>Hãy chọn món yêu thích!</p>
                        </div>
                    </div>
                    <div class="order-footer">
                        <div class="total-row">
                            <span>Tổng cộng</span>
                            <span class="total-amount" id="totalAmount">0 ₫</span>
                        </div>
                        <button type="button" id="checkoutBtn" class="checkout-btn" disabled onclick="window.location.href='/checkout-restaurant'">
                            <i class="fas fa-lock"></i> Xác nhận đặt bàn
                        </button>
                    </div>
                </div>
            </aside>
        </div>
    </main>

    <!-- Dish Detail Modal -->
    <div id="viewDishModal" class="custom-modal-overlay">
        <div class="custom-modal-content">
            <div class="custom-modal-header">
                <h5 class="custom-modal-title">Chi tiết món ăn</h5>
                <button type="button" class="custom-modal-close" id="customModalCloseBtn">&times;</button>
            </div>
            <div class="custom-modal-body">
                <div class="modal-body-layout">
                    <div class="modal-body-left"><img id="viewDishImage" src="" alt="" class="modal-dish-image"></div>
                    <div class="modal-body-right">
                        <label class="form-label-bold">Thông tin</label>
                        <div>
                            <p><strong>Tên món:</strong> <span id="modalDishName"></span></p>
                            <p><strong>Danh mục:</strong> <span id="modalDishCategory"></span></p>
                            <p><strong>Giá:</strong> <span id="modalDishPrice"></span></p>
                            <p><strong>Trạng thái:</strong> <span id="modalDishAvailabilityBadge" class="badge"></span></p>
                        </div>
                    </div>
                </div>
                <div class="modal-body-full-width">
                    <label class="form-label-bold">Mô tả</label>
                    <div id="viewDishDescription" class="modal-dish-description"></div>
                </div>
            </div>
            <div class="custom-modal-footer">
                <button type="button" class="custom-modal-footer-close" id="customModalCloseFooterBtn">Đóng</button>
            </div>
        </div>
    </div>

    @await Html.PartialAsync("Footer")

    <script>
    document.addEventListener('DOMContentLoaded', () => {
        const cart = {};
        const orderItemsEl = document.getElementById('orderItems');
        const totalAmountEl = document.getElementById('totalAmount');
        const checkoutBtn = document.getElementById('checkoutBtn');

        function formatVND(n) { return new Intl.NumberFormat('vi-VN').format(n) + ' ₫'; }

        function renderCart() {
            const items = Object.values(cart);
            if (items.length === 0) {
                orderItemsEl.innerHTML = '<div class="empty-cart-message"><i class="fas fa-shopping-cart"></i><p>Giỏ hàng trống<br>Hãy chọn món yêu thích!</p></div>';
                checkoutBtn.disabled = true;
                totalAmountEl.textContent = '0 ₫';
                return;
            }
            checkoutBtn.disabled = false;
            let total = 0;
            let html = '';
            items.forEach(item => {
                total += item.price * item.qty;
                html += `<div class="order-item">
                    <div class="order-item-left">
                        <img class="item-image" src="${item.img}" alt="${item.name}">
                        <div class="item-name">${item.name}</div>
                    </div>
                    <div class="order-item-right">
                        <div class="item-price">${formatVND(item.price)}</div>
                        <div class="item-qty-control">
                            <button class="btn-item-minus" onclick="changeQty('${item.id}', -1)">-</button>
                            <span class="item-qty">${item.qty}</span>
                            <button class="btn-item-plus" onclick="changeQty('${item.id}', 1)">+</button>
                        </div>
                        <div class="item-subtotal">Tạm tính: <span class="subtotal-price">${formatVND(item.price * item.qty)}</span></div>
                    </div>
                </div>`;
            });
            orderItemsEl.innerHTML = html;
            totalAmountEl.textContent = formatVND(total);
        }

        window.changeQty = function(id, delta) {
            if (cart[id]) {
                cart[id].qty += delta;
                if (cart[id].qty <= 0) delete cart[id];
            }
            renderCart();
        };

        // Add to cart
        document.addEventListener('click', (e) => {
            if (e.target.classList.contains('add-btn') && !e.target.disabled) {
                e.stopPropagation();
                const card = e.target.closest('.dish-card');
                if (card && card.dataset.isAvailable === 'true') {
                    const id = card.dataset.dishId;
                    if (cart[id]) { cart[id].qty++; }
                    else { cart[id] = { id, name: card.dataset.dishName, price: parseInt(card.dataset.dishPrice), img: card.dataset.dishImage, qty: 1 }; }
                    renderCart();
                }
            }
        });

        // Modal
        const viewModal = document.getElementById('viewDishModal');
        document.querySelectorAll('.dish-card').forEach(card => {
            card.addEventListener('click', (e) => {
                if (e.target.classList.contains('add-btn')) return;
                document.getElementById('viewDishImage').src = card.dataset.dishImage;
                document.getElementById('modalDishName').textContent = card.dataset.dishName;
                document.getElementById('modalDishCategory').textContent = card.dataset.dishCategory;
                document.getElementById('modalDishPrice').textContent = new Intl.NumberFormat('vi-VN').format(card.dataset.dishPrice) + ' ₫';
                document.getElementById('viewDishDescription').textContent = card.dataset.dishDescription;
                const badge = document.getElementById('modalDishAvailabilityBadge');
                badge.textContent = card.dataset.dishAvailability;
                badge.className = 'badge ' + (card.dataset.isAvailable === 'true' ? 'bg-success' : 'bg-danger');
                viewModal.classList.add('active');
            });
        });
        document.getElementById('customModalCloseBtn').addEventListener('click', () => viewModal.classList.remove('active'));
        document.getElementById('customModalCloseFooterBtn').addEventListener('click', () => viewModal.classList.remove('active'));
        viewModal.addEventListener('click', (e) => { if (e.target === viewModal) viewModal.classList.remove('active'); });

        // Search
        const searchInput = document.getElementById('dishSearchInput');
        searchInput.addEventListener('input', function() {
            const term = this.value.toLowerCase().trim();
            let visible = 0;
            document.querySelectorAll('.dish-card').forEach(card => {
                const match = card.dataset.dishName.toLowerCase().includes(term);
                card.style.display = match ? '' : 'none';
                if (match) visible++;
            });
            document.getElementById('noResultsMessage').style.display = (visible === 0 && term.length > 0) ? 'block' : 'none';
        });
    });
    </script>
</body>
</html>
