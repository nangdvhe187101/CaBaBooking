
@{
Layout = null;
}

<!DOCTYPE html>
<html lang="vi">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Cát Bà Booking - Đặt phòng homestay và nhà hàng tại Cát Bà</title>
    <link rel="stylesheet" href="~/css/HomePage/home-style.css">
    <link href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.4.0/css/all.min.css" rel="stylesheet">
    <style>
        .detail-btn {
            text-decoration: none;
            position: absolute;
            bottom: 16px;
            right: 16px;
            background-color: #28a745;
            color: #ffffff;
            border: 1px solid #28a745;
            padding: 6px 12px;
            border-radius: 4px;
            font-size: 0.9rem;
            transition: all 0.3s ease;
            z-index: 10;
            display: block;
        }
        .detail-btn:hover { background-color: #218838; border-color: #1e7e34; color: #ffffff; transform: translateY(-1px); box-shadow: 0 4px 8px rgba(0,0,0,0.1); }
        .homestay-card, .restaurant-card { position: relative; display: flex; flex-direction: column; }
        .bottom-section { display: flex; justify-content: space-between; align-items: center; margin-top: auto; padding: 8px 0; }
    </style>
</head>
<body>
@await Html.PartialAsync("Sidebar")

<!-- Hero Section -->
<section class="hero">
    <div class="hero-overlay"></div>
    <div class="hero-bg"></div>
    <div class="container">
        <div class="hero-content">
            <div class="hero-text">
                <h1>Khám phá vẻ đẹp Cát Bà</h1>
                <p>Trải nghiệm homestay đích thực và ẩm thực địa phương</p>
            </div>

            <div class="service-tabs">
                <div class="tabs-container">
                    <button class="tab-btn active" data-tab="homestay"><i class="fas fa-home"></i><span>Homestay</span></button>
                    <button class="tab-btn" data-tab="restaurant"><i class="fas fa-utensils"></i><span>Nhà hàng</span></button>
                </div>
            </div>

            <div class="search-forms">
                <!-- Homestay Search -->
                <div class="search-form active" id="homestay-form">
                    <div class="form-tabs">
                        <button class="form-tab active"><i class="fas fa-home"></i><span>Homestay</span></button>
                        <button class="form-tab"><span>Villa</span></button>
                        <button class="form-tab"><span>Phòng đôi</span></button>
                    </div>
                    <form action="/homestay-page" method="GET">
                        <div class="form-grid" style="display:flex;flex-wrap:wrap;gap:15px;align-items:end;">
                            <div class="form-field" style="flex:0 0 200px;">
                                <label>Khu vực</label>
                                <div class="input-wrapper">
                                    <i class="fas fa-map-marker-alt"></i>
                                    <select name="areaId" class="form-select">
                                        <option value="0">Tất cả khu vực</option>
                                        <option value="1">Cát Cò 1</option>
                                        <option value="2">Cát Cò 2</option>
                                        <option value="3">Trung tâm thị trấn</option>
                                    </select>
                                </div>
                            </div>
                            <div class="form-field" style="flex:0 0 220px;">
                                <label>Ngày nhận</label>
                                <div class="input-wrapper">
                                    <i class="fas fa-calendar"></i>
                                    <input type="date" name="checkIn" class="form-input">
                                </div>
                            </div>
                            <div class="form-field" style="flex:0 0 220px;">
                                <label>Ngày trả</label>
                                <div class="input-wrapper">
                                    <i class="fas fa-calendar"></i>
                                    <input type="date" name="checkOut" class="form-input">
                                </div>
                            </div>
                            <div class="form-field-group" style="flex:0 0 220px;display:flex;gap:10px;">
                                <div class="form-field" style="flex:1;">
                                    <label>Số người</label>
                                    <div class="input-wrapper">
                                        <i class="fas fa-users"></i>
                                        <input type="number" name="guests" class="form-input" min="1" value="1">
                                    </div>
                                </div>
                                <div class="form-field" style="flex:1;">
                                    <label>Số phòng</label>
                                    <div class="input-wrapper">
                                        <i class="fas fa-door-open"></i>
                                        <input type="number" name="numRooms" class="form-input" min="1" value="1">
                                    </div>
                                </div>
                            </div>
                            <div class="form-field" style="flex:0 0 200px;">
                                <button type="submit" class="search-btn"><i class="fas fa-search"></i> Tìm homestay</button>
                            </div>
                        </div>
                    </form>
                </div>

                <!-- Restaurant Search -->
                <div class="search-form" id="restaurant-form">
                    <div class="form-tabs">
                        <button class="form-tab active"><i class="fas fa-utensils"></i><span>Tất cả</span></button>
                        <button class="form-tab"><span>Hải sản</span></button>
                        <button class="form-tab"><span>Món Việt</span></button>
                        <button class="form-tab"><span>BBQ</span></button>
                    </div>
                    <form action="/restaurant-page" method="GET">
                        <div class="form-grid" style="display:flex;flex-wrap:wrap;gap:15px;align-items:end;">
                            <div class="form-field" style="flex:0 0 200px;">
                                <label>Loại hình</label>
                                <div class="input-wrapper">
                                    <i class="fas fa-utensils"></i>
                                    <select name="restaurantType" class="form-select">
                                        <option value="">Loại nhà hàng</option>
                                        <option value="1">Hải sản</option>
                                        <option value="2">Món Việt</option>
                                        <option value="3">BBQ</option>
                                    </select>
                                </div>
                            </div>
                            <div class="form-field" style="flex:0 0 220px;">
                                <label>Khu vực tại Cát Bà</label>
                                <div class="input-wrapper">
                                    <i class="fas fa-map-marker-alt"></i>
                                    <select name="areaId" class="form-select">
                                        <option value="0">Chọn khu vực</option>
                                        <option value="1">Cát Cò 1</option>
                                        <option value="2">Trung tâm</option>
                                    </select>
                                </div>
                            </div>
                            <div class="form-field" style="flex:0 0 180px;">
                                <label>Ngày đặt bàn</label>
                                <div class="input-wrapper">
                                    <i class="fas fa-calendar"></i>
                                    <input type="date" name="date" class="form-input">
                                </div>
                            </div>
                            <div class="form-field" style="flex:0 0 150px;">
                                <label>Giờ</label>
                                <div class="input-wrapper">
                                    <i class="fas fa-clock"></i>
                                    <input type="time" name="time" class="form-input">
                                </div>
                            </div>
                            <div class="form-field" style="flex:0 0 100px;">
                                <label>Số người</label>
                                <div class="input-wrapper">
                                    <i class="fas fa-users"></i>
                                    <input type="number" name="numGuests" class="form-input" min="1">
                                </div>
                            </div>
                            <div class="form-field" style="flex:0 0 150px;">
                                <button type="submit" class="search-btn"><i class="fas fa-search"></i> Tìm nhà hàng</button>
                            </div>
                        </div>
                    </form>
                </div>
            </div>

            <div class="hero-features">
                <div class="features-container">
                    <p class="features-title">Tại sao chọn chúng tôi?</p>
                    <div class="features-list">
                        <span>🏡 Homestay chính chủ</span>
                        <span>🍜 Đặc sản địa phương</span>
                        <span>🌊 View đẹp nhất</span>
                        <span>💰 Giá tốt nhất</span>
                    </div>
                </div>
            </div>
        </div>
    </div>
</section>

<!-- Featured Homestays -->
