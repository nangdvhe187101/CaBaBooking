@await Html.PartialAsync("Footer")

<style>
    .user-dropdown { display:flex;align-items:center;gap:.5rem;background:rgba(255,255,255,.1);padding:.5rem .75rem;border-radius:9999px;cursor:pointer;transition:all .3s;color:white;position:relative;z-index:1002; }
    .user-dropdown:hover { background:rgba(255,255,255,.2); }
    .user-dropdown i.fa-chevron-down { transition:transform .3s; }
    .user-dropdown.active i.fa-chevron-down { transform:rotate(180deg); }
    .dropdown-menu { display:none;position:absolute;top:100%;right:0;background:white;border-radius:1rem;box-shadow:0 25px 50px -12px rgba(0,0,0,.25);min-width:320px;z-index:1001;overflow:hidden;transform:scaleY(0);transform-origin:top;transition:all .3s cubic-bezier(.34,1.56,.64,1); }
    .dropdown-menu.show { display:block;transform:scaleY(1); }
    .top-bar-right { position:relative; }
    .user-info { padding:1.5rem;display:flex;align-items:center;gap:1rem;background:linear-gradient(135deg,#f8fafc,#f1f5f9);border-bottom:1px solid #e2e8f0; }
    .avatar { width:48px;height:48px;border-radius:50%;object-fit:cover;border:3px solid #e2e8f0; }
    .user-info strong { font-size:1rem;color:#1e293b;display:block;font-weight:600; }
    .dropdown-list { list-style:none;margin:0;padding:0; }
    .dropdown-list li { padding:1rem 1.5rem;display:flex;align-items:center;gap:1rem;color:#475569;font-size:.95rem;transition:all .3s;border-bottom:1px solid #f1f5f9;cursor:pointer; }
    .dropdown-list li:hover { background:linear-gradient(to right,#ecfdf5,#f0fdf4);color:#059669;transform:translateX(5px); }
    .dropdown-list li:last-child { border-bottom:none; }
    .dropdown-list a { color:inherit;text-decoration:none;width:100%; }
    .dropdown-list i { width:20px;text-align:center;opacity:.6;transition:all .2s; }
    .dropdown-list li:hover i { opacity:1;color:#059669; }
</style>
<script>
    document.addEventListener('DOMContentLoaded', function () {
        const tabBtns = document.querySelectorAll('.tab-btn');
        const searchForms = document.querySelectorAll('.search-form');
        tabBtns.forEach(btn => {
            btn.addEventListener('click', function () {
                const targetTab = this.getAttribute('data-tab');
                tabBtns.forEach(b => b.classList.remove('active'));
                this.classList.add('active');
                searchForms.forEach(form => {
                    form.classList.remove('active');
                    if (form.id === targetTab + '-form') form.classList.add('active');
                });
            });
        });
        const userDropdown = document.getElementById('userDropdown');
        const dropdownMenu = document.getElementById('dropdownMenu');
        if (userDropdown) {
            userDropdown.addEventListener('click', function (e) {
                e.stopPropagation();
                dropdownMenu.classList.toggle('show');
                userDropdown.classList.toggle('active');
            });
            document.addEventListener('click', function () {
                dropdownMenu.classList.remove('show');
                userDropdown.classList.remove('active');
            });
        }
    });
</script>
</body>
</html>
